{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and safety settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "safetyScore": { "type": "number" },
        "lastSeenLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        },
        "isGuardianVisible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "EmergencyContact": {
      "title": "Emergency Contact",
      "description": "Trusted guardians for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "relation": { "type": "string" },
        "notifiedOnSOS": { "type": "boolean" },
        "isPrimary": { "type": "boolean" }
      },
      "required": ["userId", "name", "phone"]
    },
    "SOSEvent": {
      "title": "SOS Event",
      "description": "Emergency SOS triggers",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "notifiedGuardians": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "timestamp", "status"]
    },
    "CommunityReport": {
      "title": "Community Report",
      "description": "User reported safety incidents",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "object" }
      },
      "required": ["userId", "type", "timestamp"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Safety alerts or SOS events",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["SOS", "COMMUNITY_REPORT"] },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "RESOLVED"] },
        "description": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["LOW", "MODERATE", "HIGH"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "userId", "latitude", "longitude", "status"]
    },
    "Evidence": {
      "title": "Evidence",
      "description": "Media evidence stored in the vault",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "mimeType": { "type": "string" },
        "fileSize": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fileName", "fileUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/contacts/{contactId}": {
      "schema": "EmergencyContact",
      "description": "Trusted guardians for a user"
    },
    "/sos_events/{eventId}": {
      "schema": "SOSEvent",
      "description": "Emergency SOS triggers"
    },
    "/reports/{reportId}": {
      "schema": "CommunityReport",
      "description": "User reported safety incidents"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Global safety alerts and reports"
    },
    "/users/{userId}/evidence/{evidenceId}": {
      "schema": "Evidence",
      "description": "User's private evidence vault"
    }
  }
}
