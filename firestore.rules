rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data, isUpdate) {
      return (isUpdate || (data.uid == request.auth.uid && data.email is string)) &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100);
    }

    function isValidContact(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20;
    }

    function isValidSOSEvent(data) {
      return data.userId == request.auth.uid &&
             data.status is string &&
             data.timestamp is timestamp;
    }

    function isValidReport(data) {
      return data.userId == request.auth.uid &&
             data.type is string &&
             data.timestamp is timestamp;
    }

    function isValidAlert(data) {
      return data.userId == request.auth.uid &&
             data.type in ['SOS', 'COMMUNITY_REPORT'] &&
             data.status in ['ACTIVE', 'RESOLVED'];
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(incoming(), false);
      allow update: if isOwner(userId) && isValidUser(incoming(), true) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'safetyScore', 'lastSeenLocation', 'isGuardianVisible', 'bio', 'bloodGroup', 'gender', 'medicalConditions', 'updatedAt']);
      
      match /evidence/{evidenceId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /contacts/{contactId} {
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidContact(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidContact(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'relation', 'notifiedOnSOS', 'isPrimary', 'status']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /sos_events/{eventId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSOSEvent(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'location', 'notifiedGuardians']);
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReport(incoming());
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAlert(incoming());
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description']))
      );
    }
  }
}
